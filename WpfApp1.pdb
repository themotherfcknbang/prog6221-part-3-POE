<Application x:Class="CyberBot.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">

    <Application.Resources>

        <!-- ── Colour Palette ── -->
        <Color x:Key="ColBgApp">#0F1117</Color>
        <Color x:Key="ColBgCard">#1A1D27</Color>
        <Color x:Key="ColBgInput">#13151E</Color>
        <Color x:Key="ColBgUserBubble">#1E3A5F</Color>
        <Color x:Key="ColBgBotBubble">#1A2535</Color>
        <Color x:Key="ColAccentBlue">#4F8EF7</Color>
        <Color x:Key="ColAccentTeal">#00C9A7</Color>
        <Color x:Key="ColAccentPurple">#9B59F5</Color>
        <Color x:Key="ColTextPrimary">#E8EDF5</Color>
        <Color x:Key="ColTextMuted">#6B7A99</Color>
        <Color x:Key="ColBorder">#252836</Color>

        <SolidColorBrush x:Key="BrBgApp"         Color="{StaticResource ColBgApp}"/>
        <SolidColorBrush x:Key="BrBgCard"        Color="{StaticResource ColBgCard}"/>
        <SolidColorBrush x:Key="BrBgInput"       Color="{StaticResource ColBgInput}"/>
        <SolidColorBrush x:Key="BrBgUserBubble"  Color="{StaticResource ColBgUserBubble}"/>
        <SolidColorBrush x:Key="BrBgBotBubble"   Color="{StaticResource ColBgBotBubble}"/>
        <SolidColorBrush x:Key="BrAccentBlue"    Color="{StaticResource ColAccentBlue}"/>
        <SolidColorBrush x:Key="BrAccentTeal"    Color="{StaticResource ColAccentTeal}"/>
        <SolidColorBrush x:Key="BrAccentPurple"  Color="{StaticResource ColAccentPurple}"/>
        <SolidColorBrush x:Key="BrTextPrimary"   Color="{StaticResource ColTextPrimary}"/>
        <SolidColorBrush x:Key="BrTextMuted"     Color="{StaticResource ColTextMuted}"/>
        <SolidColorBrush x:Key="BrBorder"        Color="{StaticResource ColBorder}"/>

        <!-- ── Send Button Style ── -->
        <Style x:Key="SendButtonStyle" TargetType="Button">
            <Setter Property="Background"   Value="{StaticResource BrAccentBlue}"/>
            <Setter Property="Foreground"   Value="White"/>
            <Setter Property="FontFamily"   Value="Segoe UI"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"      Value="22,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="22"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="#3A7AE8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="#2B66D0"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="#2A3050"/>
                                <Setter Property="Foreground" Value="#4A5070"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Input TextBox Style ── -->
        <Style x:Key="InputBoxStyle" TargetType="TextBox">
            <Setter Property="Background"        Value="Transparent"/>
            <Setter Property="Foreground"        Value="{StaticResource BrTextPrimary}"/>
            <Setter Property="CaretBrush"        Value="{StaticResource BrAccentBlue}"/>
            <Setter Property="BorderThickness"   Value="0"/>
            <Setter Property="FontFamily"        Value="Segoe UI"/>
            <Setter Property="FontSize"          Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── ScrollBar Style (thin, subtle) ── -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width"      Value="4"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border CornerRadius="2"
                                                        Background="#3A4060"
                                                        Margin="0,2"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Application.Resources>
</Application>
