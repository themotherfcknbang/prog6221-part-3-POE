<Window x:Class="CyberBot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CyberBot — Cybersecurity Awareness"
        Height="720" Width="920"
        MinHeight="540" MinWidth="680"
        Background="{StaticResource BrBgApp}"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">

    <Grid>
        <Grid.RowDefinitions>
            <!-- Header -->
            <RowDefinition Height="Auto"/>
            <!-- Chat area -->
            <RowDefinition Height="*"/>
            <!-- Input bar -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════════
             ROW 0 — HEADER
        ══════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="{StaticResource BrBgCard}"
                BorderBrush="{StaticResource BrBorder}"
                BorderThickness="0,0,0,1"
                Padding="28,18,28,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: logo + subtitle -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center">

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Shield icon (Unicode) -->
                        <Border Background="{StaticResource BrAccentBlue}"
                                CornerRadius="10"
                                Width="38" Height="38"
                                Margin="0,0,14,0">
                            <TextBlock Text="🛡"
                                       FontSize="20"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="CyberBot"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource BrTextPrimary}"/>
                            <TextBlock Text="Cybersecurity Awareness System  ·  v3.0"
                                       FontSize="11"
                                       Foreground="{StaticResource BrTextMuted}"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- Right: status + memory badge -->
                <StackPanel Grid.Column="1"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right"
                            Orientation="Vertical">

                    <!-- Online status pill -->
                    <Border CornerRadius="12"
                            Background="#1A3A2A"
                            Padding="12,4"
                            HorizontalAlignment="Right">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="7" Height="7"
                                     Fill="{StaticResource BrAccentTeal}"
                                     VerticalAlignment="Center"
                                     Margin="0,0,6,0"/>
                            <TextBlock Text="ONLINE"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource BrAccentTeal}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Memory badge (hidden until topic is detected) -->
                    <Border x:Name="MemoryBadge"
                            CornerRadius="12"
                            Background="#1A1A3A"
                            Padding="12,4"
                            Margin="0,6,0,0"
                            Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💾 "
                                       FontSize="10"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="MemoryBadgeText"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource BrAccentPurple}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════
             ROW 1 — CHAT SCROLL AREA
        ══════════════════════════════════════════ -->
        <ScrollViewer x:Name="ChatScroll"
                      Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="0,8,0,8"
                      Background="{StaticResource BrBgApp}">

            <StackPanel x:Name="ChatPanel"
                        Margin="24,8,24,8"
                        VerticalAlignment="Top"/>
        </ScrollViewer>

        <!-- ══════════════════════════════════════════
             ROW 2 — INPUT BAR
        ══════════════════════════════════════════ -->
        <Border Grid.Row="2"
                Background="{StaticResource BrBgCard}"
                BorderBrush="{StaticResource BrBorder}"
                BorderThickness="0,1,0,0"
                Padding="20,14,20,14">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Input field with rounded border -->
                <Border Grid.Column="0"
                        Background="{StaticResource BrBgInput}"
                        CornerRadius="24"
                        BorderBrush="{StaticResource BrBorder}"
                        BorderThickness="1"
                        Padding="18,0,18,0"
                        Margin="0,0,12,0">
                    <Grid>
                        <!-- Placeholder text -->
                        <TextBlock x:Name="Placeholder"
                                   Text="Ask me about cybersecurity — or type 'help'..."
                                   Foreground="{StaticResource BrTextMuted}"
                                   FontSize="13"
                                   VerticalAlignment="Center"
                                   IsHitTestVisible="False"
                                   Margin="2,0,0,0"/>

                        <TextBox x:Name="InputBox"
                                 Style="{StaticResource InputBoxStyle}"
                                 Height="44"
                                 TextChanged="InputBox_TextChanged"
                                 KeyDown="InputBox_KeyDown"/>
                    </Grid>
                </Border>

                <!-- Send button -->
                <Button x:Name="SendButton"
                        Grid.Column="1"
                        Content="Send"
                        Style="{StaticResource SendButtonStyle}"
                        Height="44"
                        MinWidth="90"
                        Click="SendButton_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
